{
  "name": "pi-prompt-enhancer",
  "version": "0.1.0",
  "description": "Minimal, configurable prompt rewriter for Pi. Markdown templates + keyword auto-picker + GPT/Claude family branching.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "prompt-enhancer",
    "prompt-engineering",
    "ai"
  ],
  "type": "module",
  "main": "./index.ts",
  "files": [
    "*.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.19.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  }
}
